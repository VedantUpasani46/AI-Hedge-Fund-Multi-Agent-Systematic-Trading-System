# AI Hedge Fund — Environment Configuration
# ==========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your API keys
# 3. NEVER commit .env to git

# ── REQUIRED: At least one LLM key ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# ── OPTIONAL: Market Data Providers ─────────────────────────────────────────
# Yahoo Finance works FREE without a key
# For production real-time data, add one of these:
ALPHA_VANTAGE_API_KEY=     # Free: 25 requests/day — alphavantage.co
POLYGON_API_KEY=           # Real-time — polygon.io (paid)
FRED_API_KEY=              # Free macro data — fred.stlouisfed.org

# ── Portfolio Settings ───────────────────────────────────────────────────────
INITIAL_CAPITAL=1000000
MAX_POSITION_SIZE=0.15
MAX_PORTFOLIO_VAR_PCT=0.02

# ── LLM Settings ─────────────────────────────────────────────────────────────
DEFAULT_LLM_MODEL=claude-sonnet-4-6
LLM_TEMPERATURE=0.1
AGENT_VERBOSE=true

# ── System ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
